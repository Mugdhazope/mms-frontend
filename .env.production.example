# Production frontend (Vite). Copy to `.env.production` before `npm run build`.
# Do not commit `.env.production` with real keys.

# --- API ---
# Leave unset when your CDN/site reverse-proxies `/api` to Django on the same
# origin (recommended). Set only if the browser must call another host, e.g.:
#   VITE_API_BASE_URL=https://api.yourdomain.com
# (no trailing slash)
# VITE_API_BASE_URL=

# --- reCAPTCHA (needed if the backend enforces captcha on votes / notes / tags) ---
VITE_RECAPTCHA_SITE_KEY=
# Optional: manual challenge key if you use a different site key for v2/manual
# VITE_RECAPTCHA_MANUAL_SITE_KEY=

# --- Demo data (must be off in production) ---
VITE_USE_SEED=false
